# Choose the default generation provider: gemini or openai.
LLM_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI. Era Voice uses this provider even when LLM_PROVIDER=gemini.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Local embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# App
APP_ENV=development
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000
